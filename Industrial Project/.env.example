# ==================================================
# UAAMS Environment Configuration
# ==================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ==================================================

# --------------------------------------------------
# Firebase Configuration (Client-side)
# Role 3 - Backend & Database Lead
# --------------------------------------------------
# These variables are safe for frontend use
# Security is enforced via Firebase rules & auth
# --------------------------------------------------

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# --------------------------------------------------
# Firebase Configuration (Server-side)
# --------------------------------------------------
# Used for admin operations (secure)
# Store as base64 encoded JSON
# --------------------------------------------------

FIREBASE_SERVICE_ACCOUNT_KEY=base64-encoded-service-account-json

# --------------------------------------------------
# Development Settings
# --------------------------------------------------

NEXT_PUBLIC_USE_EMULATORS=false

FIREBASE_AUTH_EMULATOR_PORT=9099
FIRESTORE_EMULATOR_PORT=8080
STORAGE_EMULATOR_PORT=9199

# --------------------------------------------------
# Email Service Configuration (Role 5)
# Email, Testing & DevOps Lead
# --------------------------------------------------
# Used for transactional emails:
# - Application submission confirmation
# - Decision notifications (offer/rejection)
# - Registration emails
# --------------------------------------------------

SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=UAAMS Notifications

# --------------------------------------------------
# Email System Behaviour (Role 5)
# --------------------------------------------------
# Use mock email system during development
# Prevents real emails being sent
# --------------------------------------------------

USE_EMAIL_MOCK=true

# --------------------------------------------------
# Logging & Monitoring (Role 5)
# --------------------------------------------------
# Controls logging of email events and debugging
# --------------------------------------------------

ENABLE_EMAIL_LOGGING=true
LOG_LEVEL=info

# --------------------------------------------------
# Application Settings
# --------------------------------------------------

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENVIRONMENT=development

# --------------------------------------------------
# Optional: Monitoring & Analytics
# --------------------------------------------------

# Sentry (error tracking)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
