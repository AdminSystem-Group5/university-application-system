# ==================================================
# UAAMS Environment Configuration
# Role 3 - Backend & Database Lead (Firebase Architect)
# ==================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ==================================================

# --------------------------------------------------
# Firebase Configuration (Client-side)
# --------------------------------------------------
# These variables are prefixed with NEXT_PUBLIC_ because
# they are safe to expose to the browser. Firebase API
# keys are not secrets - security is enforced through
# Firebase Security Rules and Authentication.
# --------------------------------------------------

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# --------------------------------------------------
# Firebase Configuration (Server-side)
# --------------------------------------------------
# The service account key is used for server-side
# operations that require elevated privileges.
# This should be the JSON content of your service
# account key file, base64 encoded.
# --------------------------------------------------

FIREBASE_SERVICE_ACCOUNT_KEY=base64-encoded-service-account-json

# --------------------------------------------------
# Development Settings
# --------------------------------------------------
# Set to 'true' to connect to Firebase emulators
# during local development. This prevents test data
# from polluting your production database.
# --------------------------------------------------

NEXT_PUBLIC_USE_EMULATORS=false

# Emulator ports (only used if USE_EMULATORS=true)
FIREBASE_AUTH_EMULATOR_PORT=9099
FIRESTORE_EMULATOR_PORT=8080
STORAGE_EMULATOR_PORT=9199

# --------------------------------------------------
# Email Service Configuration
# --------------------------------------------------
# SendGrid is used for transactional emails such as
# application status notifications and password resets.
# Get your API key from https://sendgrid.com
# --------------------------------------------------

SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=UAAMS Notifications

# --------------------------------------------------
# Application Settings
# --------------------------------------------------

# Base URL for the application (used for email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment identifier
NEXT_PUBLIC_ENVIRONMENT=development

# --------------------------------------------------
# Optional: Analytics & Monitoring
# --------------------------------------------------

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# Google Analytics ID (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
